#!/bin/bash

# Pre-commit hook for secrets project
# Runs tests and basic checks before allowing commits

set -e

echo "Running pre-commit checks..."

echo "Running tests..."
make tests

echo "Running govulncheck..."
if command -v govulncheck &> /dev/null; then
    make security-check
else
    echo "Warning: govulncheck not found, skipping vulnerability check"
fi

echo "All checks passed!"
exit 0